#!/usr/bin/env bash

set -euo pipefail

export DOTNET_SDK_VERSION=10.0.105-r0
export DOTNET_RUNTIME_VERSION=10.0.5-r0
export DOTNET_ASPNET_VERSION=10.0.5-r0

export REPOSITORY=aserv92/dotnet

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <sdk|runtime|aspnet>"
  exit 1
fi

target="$1"

case "${target}" in
  sdk)
    version="${DOTNET_SDK_VERSION}"
    ;;
  runtime)
    version="${DOTNET_RUNTIME_VERSION}"
    ;;
  aspnet)
    version="${DOTNET_ASPNET_VERSION}"
    ;;
  *)
    echo "Invalid argument: ${target}"
    echo "Valid options: sdk, runtime, aspnet"
    exit 1
    ;;
esac

build_push() {
  local name="${1}"
  local version="${2}"

  docker buildx \
    build \
    --push \
    -t "${REPOSITORY}-${name}:latest" \
    -t "${REPOSITORY}-${name}:${version}" \
    -t "${REPOSITORY}-${name}:${version}-$(git rev-parse --short HEAD)" \
    --build-arg "VERSION=${version}" \
    --platform 'linux/amd64,linux/arm64' \
    -f "${name}/Dockerfile" \
    .
}

build_push "${target}" "${version}"
