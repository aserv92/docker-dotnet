#!/usr/bin/env bash

set -euo pipefail

export DOTNET_SDK_VERSION=10.0.105-r0
export DOTNET_RUNTIME_VERSION=10.0.5-r0
export DOTNET_ASPNET_VERSION=10.0.5-r0

export REPOSITORY=aserv92/dotnet

export PLATFORMS='linux/amd64,linux/arm64'

build_push() {
  local name="${1}"
  local version="${2}"

  docker buildx \
    build \
    --push \
    -t "${REPOSITORY}-${name}:latest" \
    -t "${REPOSITORY}-${name}:${version}" \
    -t "${REPOSITORY}-${name}:${version}-$(git rev-parse --short HEAD)" \
    --build-arg "VERSION=${version}" \
    --platform ${PLATFORMS} \
    -f "${name}/Dockerfile" \
    .
}

build_push sdk "${DOTNET_SDK_VERSION}"
build_push runtime "${DOTNET_RUNTIME_VERSION}"
build_push aspnet "${DOTNET_ASPNET_VERSION}"
